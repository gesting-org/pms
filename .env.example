# ─── Base de datos ─────────────────────────────────────────────────────────────
# Supabase PostgreSQL — usar la connection string con pgbouncer para producción
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres?pgbouncer=true"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://tu-dominio.vercel.app"
NEXTAUTH_SECRET="genera-con: openssl rand -base64 32"

# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
SUPABASE_SECRET_KEY="service_role_key_aqui"

# ─── Portal de propietarios ────────────────────────────────────────────────────
PORTAL_JWT_SECRET="genera-con: openssl rand -base64 32"

# ─── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@gesting.com.ar"

# ─── WhatsApp Business API (opcional) ─────────────────────────────────────────
WHATSAPP_API_KEY=""
WHATSAPP_PHONE_NUMBER_ID=""

# ─── Google Drive (módulo Documentos) ─────────────────────────────────────────
# 1. Creá un proyecto en https://console.cloud.google.com
# 2. Habilitá la API: "Google Drive API"
# 3. Creá credenciales OAuth 2.0 (tipo "Web application")
# 4. Agregá el URI de redirección: https://tu-dominio.vercel.app/api/drive/callback
GOOGLE_CLIENT_ID="tu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-client-secret"
GOOGLE_REDIRECT_URI="https://tu-dominio.vercel.app/api/drive/callback"

# ─── CORS para sitio de huéspedes ─────────────────────────────────────────────
GUEST_SITE_ORIGIN="https://tu-sitio-huespedes.com"
